{
  "name": "smartcart",
  "version": "1.0.0",
  "description": "SmartCart - Node.js MVC REST API",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "frontend": "npm run dev --prefix frontend",
    "build": "npm install && npm install --prefix frontend --include=dev && npm run build --prefix frontend",
    "dev:all": "concurrently \"npm run dev\" \"npm run frontend\"",
    "seed": "node scripts/seed.js",
    "refresh:images": "node scripts/refreshProductImages.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.0",
    "mongoose": "^9.2.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "puppeteer": "^24.39.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "lucide-react": "^0.575.0",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19"
  }
}
